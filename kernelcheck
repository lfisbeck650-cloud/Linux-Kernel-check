#!/bin/bash
# kernelcheck - shows your current Linux kernel version

get_kernel_version() {
    kernel=$(uname -r)
    echo "Your current Linux kernel version is: $kernel"
}

# Optional: full info mode
case "$1" in
    full)
        echo "Full kernel information:"
        uname -a
        ;;
    *)
        get_kernel_version
        ;;
esac
